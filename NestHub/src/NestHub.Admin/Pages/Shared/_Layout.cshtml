<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - NestHub Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/NestHub.Admin.styles.css" asp-append-version="true" />
    <style>
        :root {
            --nesthub-navy: #1F5C99;
            --nesthub-orange: #F2872E;
        }

        .navbar-brand {
            font-weight: 700;
        }

        .navbar-brand .brand-nest { color: var(--nesthub-navy); }
        .navbar-brand .brand-hub { color: var(--nesthub-orange); }

        .navbar { border-bottom: 3px solid var(--nesthub-orange); }

        .nav-link.active {
            font-weight: 600;
            color: var(--nesthub-navy) !important;
        }

        .btn-primary {
            background-color: var(--nesthub-navy);
            border-color: var(--nesthub-navy);
        }

        .btn-warning {
            background-color: var(--nesthub-orange);
            border-color: var(--nesthub-orange);
            color: #fff;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white box-shadow mb-3">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-page="/Index"><span class="brand-nest">Nest</span><span class="brand-hub">Hub</span> Admin</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <ul class="navbar-nav flex-grow-1">
                            <li class="nav-item"><a class="nav-link text-dark" asp-page="/Vendors/Index">Vendor Approvals</a></li>
                            <li class="nav-item"><a class="nav-link text-dark" asp-page="/Categories/Index">Categories</a></li>
                            <li class="nav-item"><a class="nav-link text-dark" asp-page="/Reviews/Index">Review Moderation</a></li>
                            <li class="nav-item"><a class="nav-link text-dark" asp-page="/Societies/Index">Societies</a></li>
                            <li class="nav-item"><a class="nav-link text-dark" asp-page="/Audit/Index">System Audit</a></li>
                        </ul>
                        <form asp-page="/Account/Logout" method="post" class="d-flex">
                            <button type="submit" class="btn btn-outline-secondary btn-sm">Sign out</button>
                        </form>
                    }
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - NestHub Admin Portal
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
