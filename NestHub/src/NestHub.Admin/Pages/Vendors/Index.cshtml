@page
@model NestHub.Admin.Pages.Vendors.IndexModel
@{
    ViewData["Title"] = "Vendor Approvals";
}

<h1>Vendor Onboarding Queue</h1>
<p class="text-muted">Approve newly registered vendors before they go live, and award trust badges to build resident confidence.</p>

<h4 class="mt-4">Pending Approval (@Model.PendingVendors.Count)</h4>
@if (Model.PendingVendors.Count == 0)
{
    <p class="text-muted empty-state">No vendors are currently awaiting approval.</p>
}
else
{
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>Business Name</th>
                <th>WhatsApp</th>
                <th>Bio</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var vendor in Model.PendingVendors)
            {
                <tr>
                    <td>@vendor.BusinessName</td>
                    <td>@vendor.WhatsAppNumber</td>
                    <td>@vendor.Bio</td>
                    <td>
                        <form method="post" asp-page-handler="Approve" asp-route-vendorId="@vendor.Id" class="d-inline">
                            <button type="submit" class="btn btn-primary btn-sm">Approve</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<h4 class="mt-5">Approved Vendors (@Model.ApprovedVendors.Count)</h4>
@if (Model.ApprovedVendors.Count == 0)
{
    <p class="text-muted empty-state">No approved vendors yet.</p>
}
else
{
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>Business Name</th>
                <th>Subscription</th>
                <th>Trust Badge</th>
                <th>Avg Rating</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var vendor in Model.ApprovedVendors)
            {
                <tr>
                    <td>@vendor.BusinessName</td>
                    <td>@vendor.SubscriptionTier</td>
                    <td>@vendor.TrustBadgeStatus</td>
                    <td>@vendor.AverageRating.ToString("0.0")</td>
                    <td>
                        <form method="post" asp-page-handler="AwardBadge" asp-route-vendorId="@vendor.Id" class="d-inline">
                            <select name="badge" class="form-select form-select-sm d-inline w-auto">
                                <option value="IdVerified">ID Verified</option>
                                <option value="SocietyRegular">Society Regular</option>
                                <option value="None">None</option>
                            </select>
                            <button type="submit" class="btn btn-warning btn-sm">Award</button>
                        </form>
                        @if (vendor.SubscriptionTier == "Free")
                        {
                            <form method="post" asp-page-handler="UpgradeSubscription" asp-route-vendorId="@vendor.Id" class="d-inline">
                                <button type="submit" class="btn btn-outline-primary btn-sm">Upgrade to Premium</button>
                            </form>
                        }
                        <form method="post" asp-page-handler="SetFeatured" asp-route-vendorId="@vendor.Id" asp-route-isFeatured="@(!vendor.IsFeatured)" class="d-inline">
                            <button type="submit" class="btn @(vendor.IsFeatured ? "btn-secondary" : "btn-outline-secondary") btn-sm">@(vendor.IsFeatured ? "Unfeature" : "Feature")</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
