<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage
    x:Class="NestHub.Mobile.Views.Resident.ResidentOnboardingPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewmodels="clr-namespace:NestHub.Mobile.ViewModels.Resident"
    xmlns:dtos="clr-namespace:NestHub.Application.Societies.Dtos;assembly=NestHub.Application"
    xmlns:strings="clr-namespace:NestHub.Mobile.Resources.Strings"
    x:DataType="viewmodels:ResidentOnboardingViewModel"
    Title="Complete your profile"
    Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">

            <Label Text="{Binding [OnboardingTitle], Source={x:Static strings:LocalizationResourceManager.Instance}}" FontSize="22" FontAttributes="Bold" />
            <Label Text="{Binding [OnboardingSubtitle], Source={x:Static strings:LocalizationResourceManager.Instance}}" TextColor="{StaticResource Gray500}" />

            <Picker Title="{Binding [SocietyPickerTitle], Source={x:Static strings:LocalizationResourceManager.Instance}}" ItemsSource="{Binding Societies}" SelectedItem="{Binding SelectedSociety}" ItemDisplayBinding="{Binding Name}" />

            <Entry Placeholder="{Binding [BlockNumberPlaceholder], Source={x:Static strings:LocalizationResourceManager.Instance}}" Text="{Binding BlockNumber}" />
            <Entry Placeholder="{Binding [FlatNumberPlaceholder], Source={x:Static strings:LocalizationResourceManager.Instance}}" Text="{Binding FlatNumber}" />
            <Entry Placeholder="{Binding [YourNamePlaceholder], Source={x:Static strings:LocalizationResourceManager.Instance}}" Text="{Binding Name}" />

            <Button Text="{Binding [SaveButton], Source={x:Static strings:LocalizationResourceManager.Instance}}" ImageSource="icon_check" ContentLayout="Left,8" Command="{Binding SaveCommand}" IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}" />
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
