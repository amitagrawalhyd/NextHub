<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage
    x:Class="NestHub.Mobile.Views.Resident.SosPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewmodels="clr-namespace:NestHub.Mobile.ViewModels.Resident"
    xmlns:contactDtos="clr-namespace:NestHub.Application.EmergencyContacts.Dtos;assembly=NestHub.Application"
    xmlns:strings="clr-namespace:NestHub.Mobile.Resources.Strings"
    x:DataType="viewmodels:SosViewModel"
    Title="SOS">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">

            <Label Text="{Binding [SosTitle], Source={x:Static strings:LocalizationResourceManager.Instance}}" FontSize="24" FontAttributes="Bold" TextColor="{StaticResource NestHubOrange}" />
            <Label Text="{Binding [SosDescription], Source={x:Static strings:LocalizationResourceManager.Instance}}"
                   TextColor="{StaticResource Gray500}" />

            <!-- Category values are canonical identifiers matched against vendor records on the
                 backend — intentionally left untranslated so SOS routing keeps working regardless
                 of the resident's chosen display language. -->
            <Picker Title="{Binding [CategoryPickerTitle], Source={x:Static strings:LocalizationResourceManager.Instance}}" SelectedItem="{Binding Category}">
                <Picker.ItemsSource>
                    <x:Array Type="{x:Type x:String}">
                        <x:String>Plumbing</x:String>
                        <x:String>Electrical</x:String>
                        <x:String>Home Maintenance</x:String>
                        <x:String>Appliance Repair</x:String>
                        <x:String>Pest Control</x:String>
                    </x:Array>
                </Picker.ItemsSource>
            </Picker>

            <Editor Placeholder="{Binding [DescribeEmergencyPlaceholder], Source={x:Static strings:LocalizationResourceManager.Instance}}" Text="{Binding Description}" HeightRequest="100" />

            <Button Text="{Binding [SendSosButton], Source={x:Static strings:LocalizationResourceManager.Instance}}" ImageSource="icon_sos_button" ContentLayout="Left,8" BackgroundColor="{StaticResource NestHubOrange}" Command="{Binding SendSosCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}" />
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />

            <Label Text="{Binding ConfirmationMessage}" TextColor="Green" IsVisible="{Binding ConfirmationMessage, Converter={StaticResource StringNotEmptyConverter}}" />

            <BoxView HeightRequest="1" Color="{StaticResource Gray200}" />

            <Label Text="{Binding [EmergencyContactsHeader], Source={x:Static strings:LocalizationResourceManager.Instance}}" FontAttributes="Bold" FontSize="16" />

            <CollectionView ItemsSource="{Binding EmergencyContacts}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="contactDtos:EmergencyContactDto">
                        <Grid Padding="0,6" ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Grid.Column="0">
                                <Label Text="{Binding Name}" FontAttributes="Bold" />
                                <Label Text="{Binding Role}" FontSize="12" TextColor="{StaticResource Gray500}" />
                            </VerticalStackLayout>
                            <Button Grid.Column="1" Text="{Binding [CallButton], Source={x:Static strings:LocalizationResourceManager.Instance}}" ImageSource="icon_call" ContentLayout="Left,6"
                                    BackgroundColor="{StaticResource NestHubNavy}"
                                    Command="{Binding BindingContext.CallContactCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}"
                                    CommandParameter="{Binding .}" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
