<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage
    x:Class="NestHub.Mobile.Views.Resident.VendorSearchPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewmodels="clr-namespace:NestHub.Mobile.ViewModels.Resident"
    xmlns:dtos="clr-namespace:NestHub.Application.Vendors.Dtos;assembly=NestHub.Application"
    x:DataType="viewmodels:VendorSearchViewModel"
    Title="Find a vendor">

    <Grid RowDefinitions="Auto,*" Padding="16" RowSpacing="12">

        <SearchBar Grid.Row="0"
                   Placeholder="Search by name, service, or category (e.g. electrician)"
                   Text="{Binding SearchQuery}"
                   SearchCommand="{Binding SearchCommand}" />

        <CollectionView Grid.Row="1" ItemsSource="{Binding Vendors}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="dtos:VendorDto">
                    <Grid Padding="0,8">
                        <Border Padding="12" StrokeShape="RoundRectangle 10">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding BindingContext.OpenVendorCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}"
                                    CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding BusinessName}" FontAttributes="Bold" FontSize="16" />
                                <Label Text="{Binding Bio}" TextColor="{StaticResource Gray500}" LineBreakMode="TailTruncation" MaxLines="2" />
                                <Label Text="{Binding TrustBadgeStatus, StringFormat='Trust badge: {0}'}" FontSize="12" TextColor="{StaticResource NestHubOrange}" />
                                <Label Text="{Binding AverageRating, StringFormat='★ {0:0.0}'}" FontSize="12" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>
