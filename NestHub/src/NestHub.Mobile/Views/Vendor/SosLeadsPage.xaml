<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage
    x:Class="NestHub.Mobile.Views.Vendor.SosLeadsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewmodels="clr-namespace:NestHub.Mobile.ViewModels.Vendor"
    xmlns:dtos="clr-namespace:NestHub.Application.SosRequests.Dtos;assembly=NestHub.Application"
    xmlns:strings="clr-namespace:NestHub.Mobile.Resources.Strings"
    x:DataType="viewmodels:VendorSosLeadsViewModel"
    Title="SOS Leads">

    <Grid Padding="16">
        <CollectionView ItemsSource="{Binding OpenRequests}">
            <CollectionView.EmptyView>
                <Label Text="{Binding [NoOpenLeads], Source={x:Static strings:LocalizationResourceManager.Instance}}" Style="{StaticResource EmptyStateLabelStyle}" />
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="dtos:SosRequestDto">
                    <Border Style="{StaticResource CardStyle}">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="{Binding Category}" FontAttributes="Bold" FontSize="16" TextColor="{StaticResource NestHubOrange}" />
                            <Label Text="{Binding Description}" Style="{StaticResource BodyLabelStyle}" />
                            <Label Text="{Binding CreatedDateTimeUtc, Converter={StaticResource ReportedFormatConverter}}" Style="{StaticResource CaptionLabelStyle}" />
                            <Button Text="{Binding [ClaimLeadButton], Source={x:Static strings:LocalizationResourceManager.Instance}}"
                                    ImageSource="icon_flag" ContentLayout="Left,8"
                                    Command="{Binding BindingContext.ClaimCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}"
                                    CommandParameter="{Binding .}" />
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
