<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage
    x:Class="NestHub.Mobile.Views.LoginPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewmodels="clr-namespace:NestHub.Mobile.ViewModels"
    xmlns:strings="clr-namespace:NestHub.Mobile.Resources.Strings"
    x:DataType="viewmodels:LoginViewModel"
    Shell.NavBarIsVisible="False"
    Title="Sign in">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16" VerticalOptions="Center">

            <Image Source="logo_nesthub" HeightRequest="120" WidthRequest="120" HorizontalOptions="Center" />

            <HorizontalStackLayout HorizontalOptions="Center" Spacing="0">
                <Label Text="Nest" FontSize="32" FontAttributes="Bold" TextColor="{StaticResource NestHubNavy}" />
                <Label Text="Hub" FontSize="32" FontAttributes="Bold" TextColor="{StaticResource NestHubOrange}" />
            </HorizontalStackLayout>

            <Label Text="{Binding [SignInTagline], Source={x:Static strings:LocalizationResourceManager.Instance}}" FontSize="16" HorizontalOptions="Center" TextColor="{StaticResource Gray500}" />

            <Entry Placeholder="{Binding [PhoneNumberPlaceholder], Source={x:Static strings:LocalizationResourceManager.Instance}}" Keyboard="Telephone" Text="{Binding PhoneNumber}" />
            <Entry Placeholder="{Binding [PasswordPlaceholder], Source={x:Static strings:LocalizationResourceManager.Instance}}" IsPassword="True" Text="{Binding Password}" />

            <Label Text="{Binding ErrorMessage}" TextColor="Red" IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyConverter}}" />

            <Button Text="{Binding [SignInButton], Source={x:Static strings:LocalizationResourceManager.Instance}}" Command="{Binding LoginCommand}" IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}" />
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />

            <Button Text="{Binding [CreateAccountButton], Source={x:Static strings:LocalizationResourceManager.Instance}}" Command="{Binding NavigateToRegisterCommand}" BackgroundColor="Transparent" TextColor="{StaticResource Primary}" />

            <HorizontalStackLayout HorizontalOptions="Center" Spacing="12" Margin="0,12,0,0">
                <Label Text="{Binding [HelpLink], Source={x:Static strings:LocalizationResourceManager.Instance}}" TextColor="{StaticResource Gray500}" FontSize="12">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding NavigateToHelpCommand}" />
                    </Label.GestureRecognizers>
                </Label>
                <Label Text="·" TextColor="{StaticResource Gray500}" FontSize="12" />
                <Label Text="{Binding [PrivacyPolicyLink], Source={x:Static strings:LocalizationResourceManager.Instance}}" TextColor="{StaticResource Gray500}" FontSize="12">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding NavigateToPrivacyPolicyCommand}" />
                    </Label.GestureRecognizers>
                </Label>
                <Label Text="·" TextColor="{StaticResource Gray500}" FontSize="12" />
                <Label Text="{Binding [TermsLink], Source={x:Static strings:LocalizationResourceManager.Instance}}" TextColor="{StaticResource Gray500}" FontSize="12">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding NavigateToTermsCommand}" />
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
