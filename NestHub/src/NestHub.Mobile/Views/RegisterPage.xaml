<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage
    x:Class="NestHub.Mobile.Views.RegisterPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewmodels="clr-namespace:NestHub.Mobile.ViewModels"
    x:DataType="viewmodels:RegisterViewModel"
    Title="Create account">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">

            <Entry Placeholder="Phone number" Keyboard="Telephone" Text="{Binding PhoneNumber}" />
            <Entry Placeholder="Password" IsPassword="True" Text="{Binding Password}" />

            <HorizontalStackLayout Spacing="8">
                <Switch IsToggled="{Binding IsVendor}" />
                <Label Text="I'm registering as a vendor" VerticalOptions="Center" />
            </HorizontalStackLayout>

            <Label Text="{Binding ErrorMessage}" TextColor="Red" IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyConverter}}" />

            <Button Text="Register" Command="{Binding RegisterCommand}" IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}" />
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
