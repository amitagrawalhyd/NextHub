<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:NestHub.Mobile"
             xmlns:converters="clr-namespace:NestHub.Mobile.Converters"
             x:Class="NestHub.Mobile.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <converters:InvertedBoolConverter x:Key="InvertedBoolConverter" />
            <converters:StringNotEmptyConverter x:Key="StringNotEmptyConverter" />
            <converters:TierToLabelConverter x:Key="TierToLabelConverter" />
            <converters:TierToIconConverter x:Key="TierToIconConverter" />
            <converters:TierToColorConverter x:Key="TierToColorConverter" />
            <converters:CountToBoolConverter x:Key="CountToBoolConverter" />
            <converters:TrustBadgeFormatConverter x:Key="TrustBadgeFormatConverter" />
            <converters:AverageRatingFormatConverter x:Key="AverageRatingFormatConverter" />
            <converters:SubscriptionFormatConverter x:Key="SubscriptionFormatConverter" />
            <converters:ApprovalStatusFormatConverter x:Key="ApprovalStatusFormatConverter" />
            <converters:PostedFormatConverter x:Key="PostedFormatConverter" />
            <converters:ReportedFormatConverter x:Key="ReportedFormatConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
